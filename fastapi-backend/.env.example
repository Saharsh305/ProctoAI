# FastAPI settings
APP_NAME=MyProctor FastAPI
ENV=dev
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# PostgreSQL
DATABASE_URL=YOUR_DB_URL_HERE

# Auth (optional, used by auth router)
SECRET_KEY=change_me
ACCESS_TOKEN_EXPIRE_MINUTES=60
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=admin_here
MINIO_SECRET_KEY=admin_here
MINIO_BUCKET=bucket_here
MINIO_SECURE=false  # For local dev